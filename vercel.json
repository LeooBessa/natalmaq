{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "next build && rm -rf .next/cache",
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.3.1",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" }
  ],
  "crons": [
    { "path": "/api/sync/ds", "schedule": "0 5 * * *" }
  ]
}
